{
  "openai": {
    "api_endpoint": "https://coding.dashscope.aliyuncs.com/v1",
    "api_key": "your-api-key-here"
  },
  "proxy": {
    "max_retries": 5,
    "timeout": 300,
    "retry_delay": 1,
    "retry_backoff_multiplier": 2,
    "max_concurrent_requests": 50,
    "rate_limit_per_minute": 100,
    "max_request_size_mb": 10
  },
  "logging": {
    "level": "DEBUG",
    "log_dir": "logs"
  },
  "model_mapping": {
    "claude-3-5-sonnet-20241022": "qwen3.6-plus",
    "claude-3-5-haiku-20241022": "qwen-turbo",
    "claude-3-opus-20240229": "qwen-max",
    "claude-haiku-4-5-20251001": "qwen3.6-plus",
    "claude-sonnet-4-6": "qwen3.6-plus",
    "claude-opus-4-6": "qwen-max"
  },
  "security": {
    "allowed_origins": ["*"],
    "require_authentication": false,
    "api_key_header": "x-api-key"
  }
}